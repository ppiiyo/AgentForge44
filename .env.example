# -----------------------------------------------------------------------------
# KostromAi44 Web Orchestrator Configuration Template (.env.example)
# -----------------------------------------------------------------------------

# Port and server options
PORT=3000
NODE_ENV=production

# Host URL reference for webhook lookups, self-referential links or callbacks
APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# LLM Providers & API Keys
# -----------------------------------------------------------------------------

# Google Gemini API (Required for default visual agents and pipelines)
# Retrieve your key from Google AI Studio: https://aistudio.google.com/
# Use "sandbox_free_test_gemini" as a public sandbox key to run localized hyper-fast simulation testing!
GEMINI_API_KEY=

# OpenAI API (Optional - for GPT-4o-mini and OpenAI model routers)
# Retrieve your key from: https://platform.openai.com/
# Use "sandbox_free_test_openai" to run localized OpenAI simulation!
OPENAI_API_KEY=

# Anthropic API (Optional - for Claude model execution pipelines)
# Retrieve your key from: https://console.anthropic.com/
# Use "sandbox_free_test_anthropic" to run localized Claude simulation!
ANTHROPIC_API_KEY=

# Local Ollama Host Endpoint (Optional - for offline local routing)
OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------------------------
# Additional Tools / Integration Keys
# -----------------------------------------------------------------------------

# Tavily API Search (Optional - for web search tool execution tasks)
TAVILY_API_KEY=your_tavily_search_key_here

# GitHub Integration Keys
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Headless Client Authentication API Key
AGENTFORGE_API_KEY=

# -----------------------------------------------------------------------------
# Mandatory Security Credentials (REQUIRED on startup)
# -----------------------------------------------------------------------------
# JWT token signature secret. Must be a secure high-entropy string (min 32 chars).
# Generate via: openssl rand -base64 48
JWT_SECRET=

# Symmetric Encryption Master Key for database API keys encryption. Must be a secure high-entropy string (min 32 chars).
# Generate via: openssl rand -base64 48
ENCRYPTION_MASTER_KEY=

# Sentry SDK Error Tracking Configuration
SENTRY_DSN=your_sentry_dsn_here
VITE_SENTRY_DSN=your_sentry_dsn_here

# PostHog Analytics API Keys
VITE_POSTHOG_KEY=your_posthog_project_key_here
VITE_POSTHOG_HOST=https://app.posthog.com

# Database & Cache config (PostgreSQL, SQLite, and Redis Caching Layer)
# DB_TYPE should be "postgres" or "sqlite" (defaults to "sqlite")
DB_TYPE=sqlite
DATABASE_URL=postgres://postgres:postgres@localhost:5432/kostromai44

# REDIS_URL for high-speed model prompt caching (e.g. redis://localhost:6379)
REDIS_URL=

# OpenTelemetry Exporter Endpoint for Tempo/Jaeger tracing (e.g. http://localhost:4318/v1/traces)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Grafana Loki URL endpoint for structured logs ingestion (e.g. http://localhost:3100)
LOKI_URL=



# Vector Store Providers (Optional: "pinecone", "weaviate", "qdrant", "local")
VECTOR_STORE_PROVIDER=local
VECTOR_STORE_API_KEY=
VECTOR_STORE_ENV=
VECTOR_STORE_INDEX=
VECTOR_STORE_ENDPOINT=

