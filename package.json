    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "standard-version": "^9.5.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.0",
    "typescript": "~7.0.2",
    "vite": "^8.1.4",
