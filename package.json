{
  "name": "kostromai44",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Visual, low-code orchestrator and development environment for multi-agent LLM systems",
  "license": "MIT",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsx server.ts",
    "postinstall": "npm rebuild --platform=linux --arch=x64 sharp",
    "prebuild": "node scripts/ensure-oxide.cjs",
    "build": "drizzle-kit generate --config=drizzle.config.ts && drizzle-kit generate --config=drizzle-postgres.config.ts && npx tsx scripts/generate-swagger.ts && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "pretest": "drizzle-kit generate --config=drizzle.config.ts && drizzle-kit push --config=drizzle.config.ts --force",
    "test": "vitest run --exclude \"**/*.spec.ts\"",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage --exclude \"**/*.spec.ts\"",
    "test:load": "k6 run src/tests/load/pipeline.load.js",
    "test:load:stress": "k6 run src/tests/load/circuit-breaker.load.js",
    "test:load:soak": "k6 run src/tests/load/soak.load.js",
    "test:load:all": "npm run test:load && npm run test:load:stress && npm run test:load:soak",
    "lint": "eslint src && tsc --noEmit",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.ts",
    "db:push": "drizzle-kit push --config=drizzle.config.ts",
    "db:seed": "npx tsx scripts/seed-db.ts",
    "db:studio": "drizzle-kit studio",
    "release": "standard-version"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@google/genai": "^2.4.0",
    "@openfeature/core": "^1.11.0",
    "@openfeature/server-sdk": "^1.22.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@sentry/node": "^10.57.0",
    "@sentry/react": "^10.57.0",
    "@types/jszip": "^3.4.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.2.0",
    "bullmq": "^5.79.1",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dompurify": "^3.1.5",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.8",
    "helmet": "^8.2.0",
    "i18next": "^26.3.1",
    "ioredis": "^5.11.1",
    "isolated-vm": "^5.0.2",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "ollama": "^0.5.0",
    "openai": "^5.10.2",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.9",
    "posthog-js": "^1.386.6",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "react-is": "^19.0.0",
    "react-markdown": "^10.1.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "safe-regex": "^2.1.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "vectra": "^0.15.0",
    "winston": "^3.19.0",
    "workbox-window": "^7.4.1",
    "zod": "^3.25.0",
    "zustand": "^5.0.14",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
