{
  "name": "agentforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Visual, low-code orchestrator and development environment for multi-agent LLM systems",
  "license": "MIT",
  "scripts": {
    "dev": "tsx server.ts",
    "prebuild": "node scripts/ensure-oxide.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "pretest": "drizzle-kit push",
    "test": "vitest run --exclude \"**/*.spec.ts\"",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage --exclude \"**/*.spec.ts\"",
    "lint": "eslint src && tsc --noEmit",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "release": "standard-version"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.60.0",
    "@google/genai": "^2.4.0",
    "@sentry/node": "^10.57.0",
    "@sentry/react": "^10.57.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "i18next": "^26.3.1",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "ollama": "^0.5.0",
    "openai": "^5.10.2",
    "postgres": "^3.4.9",
    "posthog-js": "^1.386.6",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-i18next": "^17.0.8",
    "react-is": "^19.0.0",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "safe-regex": "^2.1.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "vectra": "^0.15.0",
    "vm2": "^3.11.5",
    "winston": "^3.19.0",
    "workbox-window": "^7.4.1",
    "zod": "^3.25.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/safe-regex": "^1.1.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "standard-version": "^9.5.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
