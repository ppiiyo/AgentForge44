    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "motion": "^12.42.2",
    "node-cron": "^4.6.0",
    "ollama": "^0.6.3",
    "openai": "^6.46.0",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.9",
    "posthog-js": "^1.399.2",
