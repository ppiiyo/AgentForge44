{
  "name": "agentforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Visual, low-code orchestrator and development environment for multi-agent LLM systems",
  "license": "MIT",
  "scripts": {
    "dev": "tsx server.ts",
    "prebuild": "node scripts/ensure-oxide.cjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "test": "vitest run --exclude \"**/*.spec.ts\"",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage --exclude \"**/*.spec.ts\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@anthropic-ai/sdk": "^0.60.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "ollama": "^0.5.0",
    "openai": "^5.10.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.25.0",
    "supertest": "^7.2.2",
    "@tailwindcss/vite": "^4.1.14",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.8"
  }
}
