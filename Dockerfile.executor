# --- Stage 1: Build Executor Worker ---
FROM node:20-slim AS builder

WORKDIR /usr/src/app

# Define build-time environment variables (default to development to ensure devDependencies are installed)
ARG NODE_ENV=development
ENV NODE_ENV=${NODE_ENV}

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    gcc \
    libc6-dev \
    && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
ENV PYTHON=/usr/bin/python3
RUN npm ci --include=dev

COPY . .

# Generate migrations, Swagger documentation, and bundle the worker with esbuild
RUN npx drizzle-kit generate && \
    npx drizzle-kit generate --config=drizzle-postgres.config.ts && \
    npx esbuild src/queue/worker-entry.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/worker.cjs

# --- Stage 2: Production Worker Container ---
FROM node:20-slim AS runner

WORKDIR /usr/src/app

ARG NODE_ENV=production
ENV NODE_ENV=${NODE_ENV}

# Copy compiled bundles, manifests, and migrations
COPY --from=builder /usr/src/app/dist/worker.cjs ./dist/worker.cjs
COPY --from=builder /usr/src/app/dist/worker.cjs.map ./dist/worker.cjs.map
COPY --from=builder /usr/src/app/package.json /usr/src/app/package-lock.json ./
COPY --from=builder /usr/src/app/drizzle ./drizzle

# Install only production-level node modules
RUN npm ci --omit=dev

# Create storage directory for local project configurations
RUN mkdir -p projects && chown -R node:node /usr/src/app

USER node

# Start the standalone queue executor worker
CMD ["node", "dist/worker.cjs"]
