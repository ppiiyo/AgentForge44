# --- Stage 1: Build Backend Bundle ---
FROM node:20-slim AS builder

WORKDIR /usr/src/app

# Define build-time environment variables for the builder stage (default to development to ensure devDependencies are installed)
ARG NODE_ENV=development
ENV NODE_ENV=${NODE_ENV}

# Install build tools required for native dependency compilation (only when necessary for compilation)
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    gcc \
    libc6-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy only package.json and package-lock.json before running install to prevent unnecessary cache invalidation
COPY package.json package-lock.json ./
RUN npm ci

COPY . .

# Generate migrations, Swagger documentation, and bundle the Express server with esbuild
RUN npx drizzle-kit generate && \
    npx drizzle-kit generate --config=drizzle-postgres.config.ts && \
    npx tsx scripts/generate-swagger.ts && \
    npx esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs

# --- Stage 2: Production Backend Container ---
FROM node:20-slim AS runner

WORKDIR /usr/src/app

ARG NODE_ENV=production
ARG PORT=3000
ENV NODE_ENV=${NODE_ENV}
ENV PORT=${PORT}

# Copy compiled bundles, manifests, and migrations
COPY --from=builder /usr/src/app/dist/server.cjs ./dist/server.cjs
COPY --from=builder /usr/src/app/dist/server.cjs.map ./dist/server.cjs.map
COPY --from=builder /usr/src/app/package.json /usr/src/app/package-lock.json ./
COPY --from=builder /usr/src/app/node_modules ./node_modules
COPY --from=builder /usr/src/app/drizzle ./drizzle
COPY --from=builder /usr/src/app/swagger.json ./swagger.json
COPY --from=builder /usr/src/app/drizzle.config.ts ./drizzle.config.ts
COPY --from=builder /usr/src/app/drizzle-postgres.config.ts ./drizzle-postgres.config.ts
COPY --from=builder /usr/src/app/drizzle.config.json ./drizzle.config.json
COPY --from=builder /usr/src/app/tsconfig.json ./tsconfig.json
COPY --from=builder /usr/src/app/vite.config.ts ./vite.config.ts
COPY --from=builder /usr/src/app/server.ts ./server.ts
COPY --from=builder /usr/src/app/src ./src

# Create storage directories
RUN mkdir -p projects && chown -R node:node /usr/src/app

USER node
EXPOSE 3000

CMD ["node", "dist/server.cjs"]
